{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "rootDir": "../..",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*.ts", "./src/*/index.ts", "./src/*"],
      "@config/*": ["./src/config/*.ts", "./src/config/*/index.ts", "./src/config/*"],
      "@controllers/*": ["./src/controllers/*.ts", "./src/controllers/*/index.ts", "./src/controllers/*"],
      "@services/*": ["./src/services/*.ts", "./src/services/*/index.ts", "./src/services/*"],
      "@routes/*": ["./src/routes/*.ts", "./src/routes/*/index.ts", "./src/routes/*"],
      "@utils/*": ["./src/utils/*.ts", "./src/utils/*/index.ts", "./src/utils/*"],
      "@domain": ["./src/types/index.ts"],
      "@domain/*": ["./src/types/*.ts", "./src/types/*/index.ts", "./src/types/*"],
      "@frappe/*": ["./src/frappe/*.ts", "./src/frappe/*/index.ts", "./src/frappe/*"],
      "@middleware/*": ["./src/middleware/*.ts", "./src/middleware/*/index.ts", "./src/middleware/*"],
      "@veloce/shared": ["./../../packages/shared/src/index.ts"],
      "@veloce/shared/*": ["./../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

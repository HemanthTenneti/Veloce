# Application Environment
NODE_ENV=development
PORT=5005
HOST=localhost

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=*

# Frappe Configuration (REQUIRED - must be set before starting the application)
# Local Docker: http://localhost:8080  (matches HTTP_PUBLISH_PORT in root .env)
# Production:   https://your-frappe-domain.com
FRAPPE_URL=http://localhost:8080

# Frappe API credentials — generate in Frappe admin:
#   http://localhost:8080/app/user/Administrator -> API Access -> Generate Keys
FRAPPE_API_KEY=your_api_key_here
FRAPPE_API_SECRET=your_api_secret_here

# Optional: Database configuration
# DATABASE_URL=



{
  "name": "@veloce/api",
  "version": "1.0.0",
  "description": "Production-ready Node.js TypeScript backend for AutoCRM",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "nodemon",
    "prod": "NODE_ENV=production tsx src/index.ts",
    "upload:assets": "tsx scripts/upload_assets.ts",
    "seed:vehicles:v4": "tsx scripts/seed_vehicles_v4.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "express",
    "typescript",
    "autocrm",
    "backend",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@veloce/shared": "*",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "stripe": "^20.4.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.19.37",
    "@types/stripe": "^8.0.416",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
